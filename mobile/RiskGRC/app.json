{
  "expo": {
    "name": "RiskGRC",
    "slug": "riskgrc",
    "version": "0.0.1",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.riskgrc.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.riskgrc.app",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Whether to access face recognition"
        }
      ]
    ],
    "scheme": "riskgrc",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "51.0.0"
  }
}
